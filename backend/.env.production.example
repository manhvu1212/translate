# Copy to .env.production and fill in values.
# OLLAMA_HOST is overridden by docker-compose.yml to host.docker.internal.

GEMMA_MODEL=gemma4:e4b
GEMMA_VISION_MODEL=gemma4:e4b
GEMMA_NUM_CTX=131072

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Origins allowed to call the API.
# Add your web domain when deployed.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

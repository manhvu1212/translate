# Ollama endpoint (install: https://ollama.com)
OLLAMA_HOST=http://localhost:11434

# Text model.
# Gemma 4 (released 2026-04-02, recommended):
#   gemma4:e2b (7.2GB, on-device)  |  gemma4:e4b (9.6GB, balanced, = latest)
#   gemma4:26b (18GB, MoE)         |  gemma4:31b (20GB, flagship)
# Gemma 3 (legacy):
#   gemma3:1b (text-only)  |  gemma3:4b  |  gemma3:12b  |  gemma3:27b
GEMMA_MODEL=gemma4:e4b

# Vision-capable model for OCR.
# All Gemma 4 tags are multimodal (text + image). E2B/E4B also have native audio.
# For Gemma 3 you need 4b or larger (1b is text-only).
GEMMA_VISION_MODEL=gemma4:e4b

# Context window (tokens). Ollama default is ~2048 — far below the model's native cap.
# gemma4:e2b/e4b native = 131072 (128K), gemma4:26b/31b = 262144 (256K).
# Larger ctx lets you translate long documents but uses more RAM
# (~1.5GB for 8K, ~20GB+ for 128K on e4b).
GEMMA_NUM_CTX=131072

# Whisper model for STT: tiny, base, small, medium, large-v3
WHISPER_MODEL=base
# GPU: WHISPER_DEVICE=cuda, WHISPER_COMPUTE_TYPE=float16
# CPU: WHISPER_DEVICE=cpu,  WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# API Key auth — leave empty to disable (dev). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Cloudflare Access team domain — leave empty to disable.
# e.g. myteam.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=

# Normalize all text files to LF in the repo; let Git auto-detect text vs binary.
* text=auto eol=lf

# Explicit text (belt and suspenders for source files)
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.toml  text eol=lf
*.env.example text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf

# Shell & Windows scripts must keep their platform's endings
*.sh    text eol=lf
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tgz   binary
*.wav   binary
*.mp3   binary
*.mp4   binary
*.m4a   binary
*.webm  binary
*.ogg   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary

# Lockfile: linguist-generated hides it in GitHub diffs
pnpm-lock.yaml -diff linguist-generated=true
